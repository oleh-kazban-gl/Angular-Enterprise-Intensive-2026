{
  "name": "instaglam",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "gl",
  "sourceRoot": "apps/instaglam/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": { "base": "dist/apps/instaglam", "browser": "" },
        "index": "apps/instaglam/src/index.html",
        "browser": "apps/instaglam/src/main.ts",
        "tsConfig": "apps/instaglam/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/instaglam/public"
          }
        ],
        "styles": ["apps/instaglam/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "instaglam:build:production"
        },
        "development": {
          "buildTarget": "instaglam:build:development"
        }
      },
      "options": {
        "proxyConfig": "apps/instaglam/proxy.conf.json"
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "instaglam:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/instaglam/jest.config.cts",
        "tsConfig": "apps/instaglam/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "instaglam:build",
        "spa": true
      }
    }
  }
}
