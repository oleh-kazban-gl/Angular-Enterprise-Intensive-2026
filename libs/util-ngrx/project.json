{
  "name": "util-ngrx",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/util-ngrx/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/util-ngrx",
        "main": "libs/util-ngrx/src/index.ts",
        "tsConfig": "libs/util-ngrx/tsconfig.lib.json",
        "assets": ["libs/util-ngrx/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/util-ngrx/jest.config.cts"
      }
    }
  }
}
